# Database — replace with your Postgres connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/carveout_router"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Email (SMTP for magic-link delivery)
# For local dev, magic links are printed to the server console when these are unset.
EMAIL_SERVER_HOST="smtp.example.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="user@example.com"
EMAIL_SERVER_PASSWORD="your-smtp-password"
EMAIL_FROM="noreply@example.com"
